# Backend configuration for Calaro (development / docker-compose)

# AI Models
LLAMA_MODEL_PATH=models/mistral-7b-instruct-v0.1.Q4_K_M.gguf
WHISPER_MODEL=base

PROJECT_NAME=Calaro AI
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Use SQLite by default; Docker Compose overrides this with Postgres.
SQLALCHEMY_DATABASE_URI=sqlite:///./calaro.db

# Comma-separated list of allowed frontend origins
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

